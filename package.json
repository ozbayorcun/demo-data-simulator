{
  "name": "demo-data-simulator",
  "version": "0.2.0",
  "description": "Generate deterministic synthetic demo, seed, fixture, and dashboard data for business workflow apps.",
  "type": "module",
  "homepage": "https://github.com/ozbayorcun/demo-data-simulator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ozbayorcun/demo-data-simulator.git"
  },
  "bugs": {
    "url": "https://github.com/ozbayorcun/demo-data-simulator/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "demo-data-simulator": "dist/cli.js",
    "dds": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "examples/agents",
    "examples/field-service/dashboard",
    "examples/field-service/README.md",
    "examples/field-service/src",
    "examples/field-service/test",
    "examples/specs",
    "scripts/smoke-field-service-dashboard.mjs",
    "scripts/smoke-scenario-pack-proof.mjs",
    "skills"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc && node scripts/mark-cli-executable.mjs",
    "check": "npm run build && npm test",
    "prepack": "npm run build",
    "smoke:field-service-dashboard": "node scripts/smoke-field-service-dashboard.mjs",
    "smoke:pack": "node scripts/smoke-pack-install.mjs",
    "smoke:scenario-proof": "npm run build && node scripts/smoke-scenario-pack-proof.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "demo-data",
    "test-data",
    "seed-data",
    "fixture-data",
    "test-fixtures",
    "synthetic-data",
    "synthetic-test-data",
    "demo-data-generator",
    "seed-data-generator",
    "agent",
    "ai-agent",
    "codex",
    "claude",
    "simulation",
    "business-workflow",
    "saas",
    "analytics-dashboard",
    "product-demo",
    "csv",
    "jsonl",
    "sql",
    "local-first",
    "workflow",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
