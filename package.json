{
  "name": "demo-data-simulator",
  "version": "0.1.0",
  "description": "Infer business workflow data models from a repo, then generate deterministic demo CSV/JSONL locally.",
  "type": "module",
  "homepage": "https://github.com/ozbayorcun/demo-data-simulator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ozbayorcun/demo-data-simulator.git"
  },
  "bugs": {
    "url": "https://github.com/ozbayorcun/demo-data-simulator/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "demo-data-simulator": "./dist/cli.js",
    "dds": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "examples/agents",
    "examples/field-service/README.md",
    "examples/field-service/src",
    "examples/field-service/test",
    "examples/specs"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc && node scripts/mark-cli-executable.mjs",
    "check": "npm run build && npm test",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "demo-data",
    "test-data",
    "seed-data",
    "synthetic-data",
    "agent",
    "codex",
    "claude",
    "simulation",
    "workflow",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
